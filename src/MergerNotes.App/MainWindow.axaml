<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MergerNotes.App.MainWindow"
        Width="940"
        Height="700"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Title="{Binding AppTitle}"
        Background="#F3EEF8">
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#241A33" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Foreground" Value="#241A33" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
  </Window.Styles>
  <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="20">
    <Border Padding="18" CornerRadius="18">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#5B3892" Offset="0" />
          <GradientStop Color="#6F4AA5" Offset="0.55" />
          <GradientStop Color="#3B225D" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <Border Width="72" Height="72" CornerRadius="20" Background="White" BorderBrush="#E2D8F3" BorderThickness="1" VerticalAlignment="Center" Padding="8">
          <Image Source="avares://MergerNotes/Assets/AppLogo.png" Stretch="Uniform" />
        </Border>
        <StackPanel Grid.Column="1" Margin="14,4,0,4" Spacing="3" VerticalAlignment="Center">
          <TextBlock Text="{Binding AppTitle}" FontSize="24" FontWeight="SemiBold" Foreground="White" />
          <TextBlock Text="{Binding AppSubtitle}" Foreground="#F4EFFF" Opacity="0.92" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="6">
          <TextBlock Text="{Binding LanguageLabel}" Foreground="#F7F2FF" Opacity="0.85" HorizontalAlignment="Right" />
          <ComboBox Width="180"
                    ItemsSource="{Binding LanguageChoices}"
                    SelectedItem="{Binding SelectedLanguageChoice, Mode=TwoWay}"
                    DisplayMemberBinding="{Binding DisplayName}" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Margin="0,12,0,0" Padding="12" CornerRadius="12" Background="#FFFFFF">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*" RowDefinitions="Auto,Auto">
        <Button x:Name="OpenBaseButton" Grid.Row="0" Grid.Column="0" Content="{Binding OpenBaseButtonText}" Padding="14,8" Background="#E8DEF7" />
        <Button x:Name="OpenIncomingButton" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" Content="{Binding OpenIncomingButtonText}" Padding="14,8" Background="#E8DEF7" />
        <Button x:Name="MergeButton" Grid.Row="0" Grid.Column="2" Margin="10,0,0,0" Content="{Binding MergeButtonText}" Padding="14,8" Background="#D9C7F0" />
        <TextBlock Grid.Row="0" Grid.Column="3"
                   Margin="10,0,0,0"
                   Text="{Binding StatusMessage}"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Row="1" Grid.ColumnSpan="4"
                   Margin="0,8,0,0"
                   Text="{Binding WorkspaceTitle}"
                   Opacity="0.78"
                   FontSize="12" />
      </Grid>
    </Border>

    <Border Grid.Row="2" Margin="0,12,0,0" Padding="12" CornerRadius="12" Background="#FFFFFF">
      <Grid RowDefinitions="Auto,Auto,Auto">
        <TextBlock Text="{Binding BaseBackupPath}" TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="{Binding IncomingBackupPath}" TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Row="2" Margin="0,4,0,0" Text="{Binding MergedOutputPath}" TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="3" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,*">
          <Border Padding="14" CornerRadius="12" Background="#FFFFFF">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding BaseBackupTitle}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding BaseSummaryText}" TextWrapping="Wrap" FontSize="13" />
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Margin="12,0,0,0" Padding="14" CornerRadius="12" Background="#FFFFFF">
            <StackPanel Spacing="6">
              <TextBlock Text="{Binding IncomingBackupTitle}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding IncomingSummaryText}" TextWrapping="Wrap" FontSize="13" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Padding="14" CornerRadius="12" Background="#FFFFFF">
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding MergeResultTitle}" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="{Binding MergeReportText}" TextWrapping="Wrap" FontSize="13" />
            <TextBlock Text="{Binding MergedSummaryText}" TextWrapping="Wrap" FontSize="13" Opacity="0.92" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
